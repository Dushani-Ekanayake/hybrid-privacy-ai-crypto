{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Start Backend Server",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--port", "8000"],
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal"
    },
    {
      "name": "Train Model",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/backend/model.py",
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal"
    }
  ]
}
